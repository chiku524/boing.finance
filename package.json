{
  "name": "boing",
  "version": "1.0.0",
  "description": "Cross-chain decentralized exchange",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm install && npm run dev",
    "dev:frontend": "cd frontend && npm install && npm start",
    "setup": "npm run setup:backend && npm run setup:frontend",
    "setup:backend": "cd backend && npm install",
    "setup:frontend": "cd frontend && npm install",
    "deploy:staging": "./deploy-backend.sh staging && ./deploy-frontend.sh staging",
    "deploy:prod": "./deploy-backend.sh production && ./deploy-frontend.sh production"
  },
