# Environment Variables for boing.finance Frontend
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# Application Environment (used by src/config.js for staging vs production bundles)
REACT_APP_ENV=development
# Options: development, staging, production (CI uses REACT_APP_ENV=staging|production)

# Backend API URL (optional - defaults to config.js values)
REACT_APP_BACKEND_URL=https://boing-api-prod.nico-chikuji.workers.dev

# IPFS Storage API Keys (optional - R2 is used by default)
# Get these from respective service providers:
# - Pinata: https://app.pinata.cloud/
# - Infura: https://infura.io/
# - Web3.Storage: https://web3.storage/
# - Storacha: https://console.storacha.network/

REACT_APP_PINATA_API_KEY=your_pinata_jwt_token_here
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here
REACT_APP_INFURA_PROJECT_SECRET=your_infura_project_secret_here
REACT_APP_WEB3_STORAGE_API_KEY=your_web3_storage_token_here
REACT_APP_STORACHA_API_KEY=your_storacha_did_key_here
REACT_APP_NFT_STORAGE_API_KEY=your_nft_storage_key_here

# Blockchain RPC URLs (optional - public fallbacks in config/networks.js)
# For mainnet production, use Infura/Alchemy for reliability
REACT_APP_ETHEREUM_RPC_URL=https://eth.llamarpc.com
REACT_APP_POLYGON_RPC_URL=https://polygon-rpc.com
REACT_APP_BSC_RPC_URL=https://bsc-dataseed.binance.org
REACT_APP_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
REACT_APP_OPTIMISM_RPC_URL=https://mainnet.optimism.io
REACT_APP_BASE_RPC_URL=https://mainnet.base.org
REACT_APP_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Boing Network L1 testnet (optional — defaults to https://testnet-rpc.boing.network/)
REACT_APP_BOING_TESTNET_RPC_URL=https://testnet-rpc.boing.network/
# Set to 1 to call the RPC URL directly from the browser (requires CORS on the node). Default uses same-origin /api/boing-rpc.
# REACT_APP_BOING_TESTNET_RPC_DIRECT=1

# Expansion networks (optional - public RPCs used by default)
REACT_APP_AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
REACT_APP_FANTOM_RPC_URL=https://rpc.ftm.tools
REACT_APP_ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
REACT_APP_LINEA_RPC_URL=https://rpc.linea.build
REACT_APP_SCROLL_RPC_URL=https://rpc.scroll.io
REACT_APP_POLYGON_ZKEVM_RPC_URL=https://zkevm-rpc.com
REACT_APP_MANTLE_RPC_URL=https://rpc.mantle.xyz
REACT_APP_BLAST_RPC_URL=https://rpc.blast.io
REACT_APP_OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
REACT_APP_MODE_RPC_URL=https://mainnet.mode.network

# Enhanced API Services
# The Graph API - For efficient blockchain data queries
# Get from: https://thegraph.com/ (you already have keys)
REACT_APP_THE_GRAPH_API_KEY=server_b5a9f838aa860fa04075c2527ec8011f
REACT_APP_THE_GRAPH_API_TOKEN=eyJhbGciOiJLTVNFUzI1NiIsInR5cCI6IkpXVCJ9..hanOsf8qIdXaFPDqyFeMb-jM2T2lkogUSAHyTpk7SOmjr9YruhCN5NaD_m-YdV57ALSBfqckVY6t7vA-V3MNEA

# Alchemy API - Enhanced blockchain RPC and data
# Get from: https://www.alchemy.com/ (you already have key)
REACT_APP_ALCHEMY_API_KEY=AnPJpd_2eIKzRWRJM9oKp

# LiFi API - Bridge aggregator for cross-chain transfers (Recommended)
# Get from: https://li.fi/ (see LIFI_API_SETUP_GUIDE.md)
# Free tier available, easier sign-up than Socket.tech
REACT_APP_LIFI_API_KEY=your_lifi_api_key_here

# Socket API - Bridge aggregator (Alternative to LiFi)
# Get from: https://socket.tech/ (see SOCKET_API_SETUP_GUIDE.md)
# Note: Socket.tech sign-up can be complex, LiFi is recommended instead
REACT_APP_SOCKET_API_KEY=your_socket_api_key_here

# CoinGecko API (optional - for higher rate limits)
# Get from: https://www.coingecko.com/en/api
REACT_APP_COINGECKO_API_KEY=your_coingecko_api_key_here

# NewsAPI.org - Crypto/DeFi news feed on Analytics
# Get from: https://newsapi.org/ (free tier: 100 req/day)
REACT_APP_NEWSAPI_KEY=

# NewsAPI.ai (Event Registry) - optional; for richer news/sentiment later
# Get from: https://newsapi.ai/
REACT_APP_NEWSAPI_AI_KEY=

# Etherscan API (optional - for higher rate limits)
# Get from: https://etherscan.io/apis
REACT_APP_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Solana (optional - defaults to devnet)
# Set to 'mainnet' for production
REACT_APP_SOLANA_NETWORK=devnet
REACT_APP_SOLANA_DEVNET_RPC=https://api.devnet.solana.com
REACT_APP_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com

# Note: API keys in this file are exposed to the frontend bundle
# Only use keys that are safe to expose (public API keys)
# For sensitive keys, use backend environment variables

