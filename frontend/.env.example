# Environment Variables for boing.finance Frontend
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# Application Environment
REACT_APP_ENVIRONMENT=development
# Options: development, staging, production

# Backend API URL (optional - defaults to config.js values)
REACT_APP_BACKEND_URL=https://boing-api-prod.nico-chikuji.workers.dev

# IPFS Storage API Keys (optional - R2 is used by default)
# Get these from respective service providers:
# - Pinata: https://app.pinata.cloud/
# - Infura: https://infura.io/
# - Web3.Storage: https://web3.storage/
# - Storacha: https://console.storacha.network/

REACT_APP_PINATA_API_KEY=your_pinata_jwt_token_here
REACT_APP_INFURA_PROJECT_ID=your_infura_project_id_here
REACT_APP_INFURA_PROJECT_SECRET=your_infura_project_secret_here
REACT_APP_WEB3_STORAGE_API_KEY=your_web3_storage_token_here
REACT_APP_STORACHA_API_KEY=your_storacha_did_key_here
REACT_APP_NFT_STORAGE_API_KEY=your_nft_storage_key_here

# Blockchain RPC URLs (optional - defaults in config/networks.js)
REACT_APP_ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
REACT_APP_POLYGON_RPC_URL=https://polygon-rpc.com
REACT_APP_BSC_RPC_URL=https://bsc-dataseed.binance.org
REACT_APP_ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
REACT_APP_OPTIMISM_RPC_URL=https://mainnet.optimism.io
REACT_APP_BASE_RPC_URL=https://mainnet.base.org
REACT_APP_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Note: API keys in this file are exposed to the frontend bundle
# Only use keys that are safe to expose (public API keys)
# For sensitive keys, use backend environment variables

