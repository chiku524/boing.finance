    "axios": "^1.6.0",
    "buffer": "^6.0.3",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "ethers": "^6.8.1",
    "framer-motion": "^10.16.4",
    "i18next": "^23.7.6",
    "lucide-react": "^0.292.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.43.9",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^13.5.0",
