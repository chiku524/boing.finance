  "scripts": {
    "dev": "vite",
    "start": "vite",
    "prebuild": "node scripts/update-service-worker-version.js && node scripts/generate-version-manifest.js",
    "build": "npm run generate-manifest && cross-env CI=false vite build",
    "build:prod": "cross-env CI=false REACT_APP_ENV=production vite build",
    "build:staging": "cross-env CI=false REACT_APP_ENV=staging vite build",
    "preview": "vite preview",
    "test": "echo \"No unit tests configured\" && exit 0",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "setup-base": "node scripts/setup-base-miniapp.js",
    "generate-manifest": "node scripts/generate-manifest.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "globals": {
      "BigInt": "readonly"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.6",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  },
  "overrides": {
    "@solana/codecs": "2.3.0",
    "@solana/codecs-core": "2.3.0",
    "@solana/codecs-data-structures": "2.3.0",
    "@solana/codecs-numbers": "2.3.0",
    "@solana/codecs-strings": "2.3.0"
  }
